{
  "name": "fhe-casino",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:shared": "mocha --timeout 15000 -r ts-node/register -r hardhat/register test/FHEShared.test.ts",
    "test:mines": "mocha --timeout 20000 -r ts-node/register -r hardhat/register test/FHEMines.test.ts",
    "test:crash": "mocha --timeout 20000 -r ts-node/register -r hardhat/register test/FHECrash.test.ts",
    "test:hilo": "mocha --timeout 20000 -r ts-node/register -r hardhat/register test/FHEHiLo.test.ts",
    "test:plinko": "mocha --timeout 20000 -r ts-node/register -r hardhat/register test/FHEPlinko.test.ts",
    "clean": "hardhat clean",
    "deploy:shared": "hardhat run scripts/deploy-shared.ts",
    "deploy:casino": "hardhat run scripts/deploy-casino.ts",
    "check:sepolia": "hardhat run scripts/check-sepolia-ready.ts --network eth-sepolia",
    "check:nitrogen": "hardhat run scripts/check-nitrogen-ready.ts --network fhenix-nitrogen",
    "smoke:sepolia": "hardhat run scripts/smoke-runtime.ts --network eth-sepolia",
    "smoke:nitrogen": "hardhat run scripts/smoke-runtime.ts --network fhenix-nitrogen",
    "deposit:bankroll": "hardhat run scripts/deposit-bankroll.ts",
    "fund:local": "hardhat run scripts/fund-local-wallet.ts",
    "withdraw:bankroll": "hardhat run scripts/withdraw-bankroll.ts",
    "register:game": "hardhat run scripts/register-game.ts",
    "dev:web": "corepack pnpm --dir frontend dev",
    "build:web": "corepack pnpm --dir frontend build",
    "typecheck:web": "corepack pnpm exec tsc --project frontend/tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@openzeppelin/contracts": "^5.4.0",
    "@fhenixprotocol/cofhe-contracts": "0.0.13",
    "@fhenixprotocol/cofhe-mock-contracts": "^0.3.1",
    "@nomicfoundation/hardhat-ethers": "^3.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.5.2",
    "chai": "^4.5.0",
    "cofhe-hardhat-plugin": "^0.3.1",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.26.3",
    "mocha": "^10.8.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
